---
import MainLayout from "../../layouts/MainLayout.astro";
import UserSettingsSidebar from "../../components/UserSettingsSidebar.astro";
import UserPrivacyPageIsland from "../../components/islands/UserPrivacyPageIsland";
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:4000/api";
---

<MainLayout title="Приватность — Страницы памяти">
  <div class="bg-gray-200 min-h-screen py-6">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-6">
        <main class="flex-1">
          <div class="bg-white rounded-xl shadow-md p-8">
            <h1 class="text-2xl font-bold text-slate-700 mb-6">Приватность</h1>

            <form id="privacy-form" class="space-y-6">
              <div class="mb-2">
                <h2 class="text-lg font-semibold text-slate-700 mb-2">Настройки профиля</h2>
                <p class="text-sm text-gray-500">Управляйте видимостью вашего профиля</p>
              </div>

              <div class="space-y-4">
                <label class="flex items-start gap-3 p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50">
                  <input type="radio" name="profile_type" value="public" class="mt-1" checked />
                  <span>
                    <span class="font-medium text-gray-900">Открытый профиль</span>
                    <span class="block text-sm text-gray-500">Ваш профиль виден всем пользователям</span>
                  </span>
                </label>

                <label class="flex items-start gap-3 p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50">
                  <input type="radio" name="profile_type" value="private" class="mt-1" />
                  <span>
                    <span class="font-medium text-gray-900">Закрытый профиль</span>
                    <span class="block text-sm text-gray-500">Только вы можете видеть свой профиль</span>
                  </span>
                </label>
              </div>

              <div class="border-t border-gray-200 pt-6 space-y-4">
                <h3 class="font-semibold text-gray-900">Дополнительные настройки</h3>

                <label class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                  <span>
                    <span class="font-medium text-gray-900">Показывать email</span>
                    <span class="block text-sm text-gray-500">Другие пользователи смогут видеть ваш email</span>
                  </span>
                  <input type="checkbox" name="show_email" class="w-5 h-5" />
                </label>

                <label class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                  <span>
                    <span class="font-medium text-gray-900">Показывать созданные мемориалы</span>
                    <span class="block text-sm text-gray-500">Список ваших мемориалов будет виден другим</span>
                  </span>
                  <input type="checkbox" name="show_memorials" class="w-5 h-5" checked />
                </label>
              </div>

              <div class="flex gap-4 pt-4">
                <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-lg transition-colors font-medium">Сохранить настройки</button>
              </div>
            </form>
          </div>
        </main>

        <UserSettingsSidebar active="privacy" />
      </div>
    </div>
  </div>

  <UserPrivacyPageIsland apiBaseUrl={API_BASE_URL} client:idle />
</MainLayout>
