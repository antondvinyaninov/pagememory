---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdminPage } from "../../lib/admin-access";
import { getApiBaseUrl } from "../../lib/api-url";

const API_BASE_URL = getApiBaseUrl();
const adminGuard = await requireAdminPage(Astro, API_BASE_URL);
if (adminGuard instanceof Response) {
  return adminGuard;
}
const { cookieHeader } = adminGuard;

let stats = { users: 0, memorials: 0, memories: 0 };
let recentMemorials = [];
let recentUsers = [];
let errorMessage = "";

try {
  const res = await fetch(`${API_BASE_URL}/admin/dashboard`, {
    credentials: "include",
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    stats = { ...stats, ...(data?.stats ?? {}) };
    recentMemorials = Array.isArray(data?.recent_memorials) ? data.recent_memorials : [];
    recentUsers = Array.isArray(data?.recent_users) ? data.recent_users : [];
  } else if (res.status === 401) {
    errorMessage = "Требуется вход администратора.";
  }
} catch {
  errorMessage = "Не удалось загрузить данные админ-панели.";
}
---

<AdminLayout title="Главная" active="index">
  <div class="p-4 sm:p-6 lg:p-8">
    {errorMessage && (
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
        {errorMessage}
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-6">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Пользователей</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-800 mt-2">{stats.users}</p>
      </div>
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Мемориалов</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-800 mt-2">{stats.memorials}</p>
      </div>
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Воспоминаний</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-800 mt-2">{stats.memories}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-6">
      <a href="/admin/users" class="bg-white rounded-lg shadow p-4 sm:p-6 hover:shadow-lg transition-shadow">
        <h3 class="text-base sm:text-lg font-semibold text-slate-800 mb-2">Управление пользователями</h3>
        <p class="text-xs sm:text-sm text-gray-600">Просмотр и модерация пользователей</p>
      </a>
      <a href="/admin/memorials" class="bg-white rounded-lg shadow p-4 sm:p-6 hover:shadow-lg transition-shadow">
        <h3 class="text-base sm:text-lg font-semibold text-slate-800 mb-2">Управление мемориалами</h3>
        <p class="text-xs sm:text-sm text-gray-600">Просмотр и модерация мемориалов</p>
      </a>
    </div>

    <div class="bg-white rounded-lg shadow mb-6">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
        <h3 class="text-base sm:text-lg font-semibold text-slate-800">Последние пользователи</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Имя</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Email</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Дата</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {recentUsers.map((user) => (
              <tr>
                <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">{user.name}</td>
                <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 hidden sm:table-cell">{user.email}</td>
                <td class="px-4 sm:px-6 py-4 text-sm text-gray-500">{String(user.created_at || "").slice(0, 10)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
        <h3 class="text-base sm:text-lg font-semibold text-slate-800">Последние мемориалы</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Имя</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Дата</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {recentMemorials.length > 0 ? (
              recentMemorials.map((memorial) => (
                <tr>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">
                    <a href={`/memorial/id${memorial.id}`} class="text-blue-600 hover:underline">
                      {memorial.last_name} {memorial.first_name}
                    </a>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500">{String(memorial.updated_at || "").slice(0, 10)}</td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="2" class="px-4 sm:px-6 py-4 text-sm text-gray-500">Данные о мемориалах пока недоступны.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>
