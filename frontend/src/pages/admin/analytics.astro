---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminAnalyticsPageIsland from "../../components/islands/AdminAnalyticsPageIsland";
import { requireAdminPage } from "../../lib/admin-access";
import { getApiBaseUrl } from "../../lib/api-url";
const API_BASE_URL = getApiBaseUrl();
const CLIENT_API_URL = import.meta.env.DEV ? 'http://localhost:4000/api' : '/api';
const adminGuard = await requireAdminPage(Astro, API_BASE_URL);
if (adminGuard instanceof Response) {
  return adminGuard;
}
const { cookieHeader } = adminGuard;
let gtmId = import.meta.env.PUBLIC_GTM_ID ?? "";
let errorMessage = "";

try {
  const res = await fetch(`${API_BASE_URL}/admin/analytics`, {
    credentials: "include",
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    gtmId = String(data?.gtm_id ?? "");
  } else if (res.status === 401) {
    errorMessage = "Требуется вход администратора.";
  }
} catch {
  errorMessage = "Не удалось загрузить настройки аналитики.";
}
---

<AdminLayout title="Метрики" active="analytics">
  <div class="p-4 sm:p-6 lg:p-8">
    {errorMessage && (
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">{errorMessage}</div>
    )}

    <div class="bg-white rounded-lg shadow">
      <div class="border-b border-gray-200 px-6 py-4">
        <h2 class="text-xl font-semibold text-slate-700">Google Tag Manager</h2>
        <p class="text-sm text-gray-500 mt-1">Подключите GTM для управления всеми счетчиками аналитики</p>
      </div>

      <form id="analytics-form" class="p-6 space-y-6">
        <div>
          <label for="gtm_id" class="block text-sm font-medium text-gray-700 mb-2">GTM Container ID</label>
          <input type="text" name="gtm_id" id="gtm_id" value={gtmId} placeholder="GTM-XXXXXXX" class="w-full px-4 py-2 border border-gray-300 rounded-lg" />
          <p class="mt-1 text-xs text-gray-500">Например: GTM-XXXXXXX</p>
        </div>

        <div class="flex gap-3 pt-4 border-t">
          <button type="submit" class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium">Сохранить настройки</button>
        </div>
      </form>

      <div class="border-t border-gray-200 px-6 py-4 bg-gray-50">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Инструкция</h3>
        <ol class="space-y-2 text-sm text-gray-600 list-decimal pl-4">
          <li>Создайте контейнер в GTM.</li>
          <li>Скопируйте ID формата GTM-XXXXXXX.</li>
          <li>Сохраните ID в этой форме.</li>
        </ol>
      </div>
    </div>
  </div>

  <AdminAnalyticsPageIsland apiBaseUrl={CLIENT_API_URL} client:idle />
</AdminLayout>
