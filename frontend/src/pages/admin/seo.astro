---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdminPage } from "../../lib/admin-access";

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:4000/api";
const adminGuard = await requireAdminPage(Astro, API_BASE_URL);
if (adminGuard instanceof Response) {
  return adminGuard;
}
const SITE_URL = Astro.url.origin;

let published = 0;
let updatedLastWeek = 0;

try {
  const res = await fetch(`${API_BASE_URL}/memorials/home`);
  if (res.ok) {
    const data = await res.json();
    const recent = Array.isArray(data?.recentMemorials) ? data.recentMemorials : [];
    published = Number(data?.stats?.memorials ?? 0);
    updatedLastWeek = recent.filter((item) => {
      const date = new Date(item.updated_at || "");
      const now = new Date();
      return now.getTime() - date.getTime() <= 7 * 24 * 60 * 60 * 1000;
    }).length;
  }
} catch {
  // ignore
}

const checks = [
  { name: "sitemap.xml", ok: true, details: "Маршрут sitemap.xml доступен в Astro" },
  { name: "robots.txt", ok: true, details: "Файл robots.txt используется из public/" },
  { name: "HTTPS", ok: SITE_URL.startsWith("https://"), details: `Текущий origin: ${SITE_URL}` },
];
---

<AdminLayout title="SEO" active="seo">
  <div class="p-4 sm:p-6 lg:p-8 space-y-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-6">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Опубликовано мемориалов</p>
        <p class="text-2xl font-bold text-slate-800 mt-2">{published}</p>
      </div>
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Обновлено за 7 дней</p>
        <p class="text-2xl font-bold text-slate-800 mt-2">{updatedLastWeek}</p>
      </div>
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">Sitemap URL</p>
        <a href="/sitemap.xml" class="text-sm text-blue-600 hover:underline break-all">/sitemap.xml</a>
      </div>
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <p class="text-xs sm:text-sm text-gray-600">robots.txt</p>
        <a href="/robots.txt" class="text-sm text-blue-600 hover:underline break-all">/robots.txt</a>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
        <h3 class="text-base sm:text-lg font-semibold text-slate-800">Технический SEO-чеклист</h3>
      </div>
      <div class="divide-y divide-gray-200">
        {checks.map((check) => (
          <div class="px-4 sm:px-6 py-4 flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-800">{check.name}</p>
              <p class="text-xs text-gray-500 mt-1">{check.details}</p>
            </div>
            <span class:list={["inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold", check.ok ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"]}>
              {check.ok ? "OK" : "Проверить"}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</AdminLayout>
