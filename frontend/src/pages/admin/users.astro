---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminUsersPageIsland from "../../components/islands/AdminUsersPageIsland";
import { requireAdminPage } from "../../lib/admin-access";

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:4000/api";
const adminGuard = await requireAdminPage(Astro, API_BASE_URL);
if (adminGuard instanceof Response) {
  return adminGuard;
}
const { cookieHeader } = adminGuard;
const page = Number(Astro.url.searchParams.get("page") || "1");

let users: Array<{
  id: number;
  name: string;
  email: string;
  role: string;
  memorials_count: number;
  is_memorial?: boolean;
}> = [];

let totalPages = 1;
let errorMessage = "";

try {
  const res = await fetch(`${API_BASE_URL}/admin/users?page=${page}`, {
    credentials: "include",
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    users = Array.isArray(data?.data) ? data.data : [];
    totalPages = Number(data?.pagination?.total_pages ?? 1);
  } else if (res.status === 401) {
    errorMessage = "Требуется вход администратора.";
  }
} catch {
  errorMessage = "Не удалось загрузить список пользователей.";
}
---

<AdminLayout title="Пользователи" active="users">
  <div class="p-4 sm:p-6 lg:p-8">
    {errorMessage && (
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">{errorMessage}</div>
    )}

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Имя</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden lg:table-cell">Email</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Роль</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Мемориалов</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Действия</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {users.length > 0 ? (
              users.map((user) => (
                <tr>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">{user.id}</td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">
                    <a href={`/user/id${user.id}`} class="text-blue-600 hover:underline flex items-center gap-1">
                      {user.name}
                      {user.is_memorial && <span class="text-sm" title="Светлая память">🕊️</span>}
                    </a>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 hidden lg:table-cell">{user.email}</td>
                  <td class="px-4 sm:px-6 py-4 text-sm hidden sm:table-cell">
                    <span class:list={["px-2 py-1 text-xs rounded-full", user.role === "admin" ? "bg-red-100 text-red-800" : "bg-gray-100 text-gray-800"]}>
                      {user.role === "admin" ? "Админ" : "Пользователь"}
                    </span>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 hidden sm:table-cell">{Number(user.memorials_count ?? 0)}</td>
                  <td class="px-4 sm:px-6 py-4 text-sm">
                    {user.role !== "admin" && (
                      <button type="button" class="text-red-600 hover:text-red-800 text-xs sm:text-sm" data-delete-user={user.id}>Удалить</button>
                    )}
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="6" class="px-4 sm:px-6 py-4 text-sm text-gray-500">Пользователи не найдены.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
      <div class="px-4 sm:px-6 py-4 border-t border-gray-200 flex items-center justify-between text-sm">
        <a class:list={["px-3 py-1.5 rounded border", page > 1 ? "border-gray-300 text-gray-700 hover:bg-gray-50" : "border-gray-200 text-gray-400 pointer-events-none"]} href={page > 1 ? `/admin/users?page=${page - 1}` : "#"}>Назад</a>
        <span>Страница {page} из {totalPages}</span>
        <a class:list={["px-3 py-1.5 rounded border", page < totalPages ? "border-gray-300 text-gray-700 hover:bg-gray-50" : "border-gray-200 text-gray-400 pointer-events-none"]} href={page < totalPages ? `/admin/users?page=${page + 1}` : "#"}>Далее</a>
      </div>
    </div>
  </div>

  <AdminUsersPageIsland apiBaseUrl={API_BASE_URL} client:idle />
</AdminLayout>
