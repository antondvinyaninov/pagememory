---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminMemorialsPageIsland from "../../components/islands/AdminMemorialsPageIsland";
import { requireAdminPage } from "../../lib/admin-access";
import { getApiBaseUrl } from "../../lib/api-url";

const status = Astro.url.searchParams.get("status") ?? "all";
const API_BASE_URL = getApiBaseUrl();
const CLIENT_API_URL = import.meta.env.DEV ? 'http://localhost:4000/api' : '/api';
const adminGuard = await requireAdminPage(Astro, API_BASE_URL);
if (adminGuard instanceof Response) {
  return adminGuard;
}
const { cookieHeader } = adminGuard;
const page = Number(Astro.url.searchParams.get("page") || "1");

let memorials = [];
let totalPages = 1;
let errorMessage = "";
try {
  const res = await fetch(`${API_BASE_URL}/admin/memorials?status=${encodeURIComponent(status)}&page=${page}`, {
    credentials: "include",
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    memorials = Array.isArray(data?.data) ? data.data : [];
    totalPages = Number(data?.pagination?.total_pages ?? 1);
  } else if (res.status === 401) {
    errorMessage = "Требуется вход администратора.";
  }
} catch {
  errorMessage = "Не удалось загрузить список мемориалов.";
}
---

<AdminLayout title="Мемориалы" active="memorials">
  <div class="p-4 sm:p-6 lg:p-8">
    {errorMessage && (
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">{errorMessage}</div>
    )}

    <div class="mb-4 flex gap-2">
      <a href="/admin/memorials?status=all&page=1" class:list={["px-4 py-2 rounded", status === "all" ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300"]}>Все</a>
      <a href="/admin/memorials?status=published&page=1" class:list={["px-4 py-2 rounded", status === "published" ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300"]}>Опубликованные</a>
      <a href="/admin/memorials?status=draft&page=1" class:list={["px-4 py-2 rounded", status === "draft" ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300"]}>Черновики</a>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Имя</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Статус</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Дата</th>
              <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Действия</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {memorials.length > 0 ? (
              memorials.map((memorial) => (
                <tr>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">{memorial.id}</td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900">
                    <a href={`/memorial/id${memorial.id}`} class="text-blue-600 hover:underline">{memorial.last_name} {memorial.first_name}</a>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm hidden sm:table-cell">
                    <span class:list={["px-2 py-1 text-xs rounded-full", memorial.status === "published" ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800"]}>
                      {memorial.status === "published" ? "Опубликован" : "Черновик"}
                    </span>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 hidden sm:table-cell">{String(memorial.created_at || "").slice(0, 10)}</td>
                  <td class="px-4 sm:px-6 py-4 text-sm">
                    <div class="flex items-center gap-2">
                      <a href={`/memorial/id${memorial.id}/edit`} class="text-blue-600 hover:text-blue-800 text-xs sm:text-sm">Редактировать</a>
                      <span class="text-gray-300">|</span>
                      <button type="button" class="text-red-600 hover:text-red-800 text-xs sm:text-sm" data-delete-memorial={memorial.id}>Удалить</button>
                    </div>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="5" class="px-4 sm:px-6 py-4 text-sm text-gray-500">Список мемориалов пока пуст.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
      <div class="px-4 sm:px-6 py-4 border-t border-gray-200 flex items-center justify-between text-sm">
        <a class:list={["px-3 py-1.5 rounded border", page > 1 ? "border-gray-300 text-gray-700 hover:bg-gray-50" : "border-gray-200 text-gray-400 pointer-events-none"]} href={page > 1 ? `/admin/memorials?status=${status}&page=${page - 1}` : "#"}>Назад</a>
        <span>Страница {page} из {totalPages}</span>
        <a class:list={["px-3 py-1.5 rounded border", page < totalPages ? "border-gray-300 text-gray-700 hover:bg-gray-50" : "border-gray-200 text-gray-400 pointer-events-none"]} href={page < totalPages ? `/admin/memorials?status=${status}&page=${page + 1}` : "#"}>Далее</a>
      </div>
    </div>
  </div>

  <AdminMemorialsPageIsland apiBaseUrl={CLIENT_API_URL} client:idle />
</AdminLayout>
