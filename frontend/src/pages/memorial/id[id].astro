                      <h2 class="flex items-center gap-2 text-base font-semibold text-white sm:text-lg">
                        <svg class="h-4 w-4 text-sky-200 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                        Воспоминания
                      </h2>
                      <div id="memory-relationship-container" class="hidden w-full sm:w-auto flex-shrink-0">
                        <select
                          id="memory-relationship-type"
                          name="relationship_type"
                          form="memory-create-form"
                          class="w-full sm:w-auto rounded-lg border border-sky-200 bg-white px-3 py-2 text-xs sm:px-4 sm:text-sm focus:border-transparent focus:ring-2 focus:ring-sky-200"
                        >
                          <option value="">Кто вы для {declineToGenitive(memorial.first_name)}?</option>
                          <optgroup label="Семья">
                            <option value="husband">Муж</option>
                            <option value="wife">Жена</option>
                            <option value="father">Отец</option>
                            <option value="mother">Мать</option>
                            <option value="son">Сын</option>
                            <option value="daughter">Дочь</option>
                            <option value="brother">Брат</option>
                            <option value="sister">Сестра</option>
                            <option value="grandfather">Дедушка</option>
                            <option value="grandmother">Бабушка</option>
                            <option value="grandson">Внук</option>
                            <option value="granddaughter">Внучка</option>
                            <option value="uncle">Дядя</option>
                            <option value="aunt">Тетя</option>
                            <option value="nephew">Племянник</option>
                            <option value="niece">Племянница</option>
                            <option value="relative">Родственник</option>
                          </optgroup>
                          <optgroup label="Другие связи">
                            <option value="friend_male">Друг</option>
                            <option value="friend_female">Подруга</option>
                            <option value="colleague">Коллега</option>
                            <option value="neighbor">Сосед</option>
                            <option value="classmate">Одноклассник</option>
                            <option value="coursemate">Однокурсник</option>
                            <option value="other">Другое</option>
                          </optgroup>
                          <option value="not_specified">Не хочу указывать</option>
                        </select>
                      </div>
                    </header>
                  </section>
                  <div class="mt-4 space-y-4">
                    <div class="rounded-2xl border border-slate-300 bg-white p-4 shadow-md">
                      <div class="mb-4">
                    <div id="memory-create-guest" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4">
                      <p class="text-sm text-slate-700">
                        Войдите, чтобы оставить воспоминание.
                      </p>
                      <a href="/login" class="mt-3 inline-flex items-center rounded-lg bg-red-500 px-4 py-2 text-sm font-medium text-white hover:bg-red-600 transition-colors">
                        Войти
                      </a>
                    </div>

                    <form id="memory-create-form" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4" enctype="multipart/form-data">
                      <div id="memory-relationship-custom-container" class="hidden mb-4">
                        <input
                          type="text"
                          id="memory-relationship-custom"
                          name="relationship_custom"
                          placeholder="Укажите вашу связь"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-transparent focus:ring-2 focus:ring-sky-200 sm:px-4"
                        />
                      </div>
                      <label for="memory-content" class="block text-sm font-medium text-slate-700 mb-2">
                        Поделитесь воспоминанием
                      </label>
                      <textarea
                        id="memory-content"
                        name="content"
                        required
                        minlength="10"
                        rows="4"
                        placeholder="Напишите ваше воспоминание..."
