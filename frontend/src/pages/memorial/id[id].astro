                      <div class="mt-3 flex flex-col sm:flex-row justify-between items-stretch sm:items-center gap-3">
                        <label class="flex items-center justify-center gap-2 px-3 sm:px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer text-sm">
                          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <span class="hidden sm:inline">Добавить фото/видео</span>
                          <span class="sm:hidden">Фото/видео</span>
                          <input type="file" id="memory-media-input" name="media" multiple accept="image/*,video/*" class="hidden">
                        </label>
                        <div class="flex items-center gap-3">
                          <button
                            type="submit"
                            id="memory-submit-btn"
                            class="flex items-center justify-center gap-2 rounded-lg bg-red-500 px-4 py-2 text-sm font-medium text-white hover:bg-red-600 transition-colors"
                          >
                            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                            Опубликовать
                          </button>
                        </div>
                      </div>
                      <p id="memory-create-status" class="text-xs text-slate-500 mt-2"></p>
                      <div id="memory-media-preview" class="mt-3 hidden"></div>
                    </form>
                  </div>

                  {memorial.memories && memorial.memories.length > 0 ? (
                    <div class="space-y-4">
                      {memorial.memories.map((memory) => (
                        <article data-memory-card data-memory-id={String(memory.id)} data-memory-author-id={String(memory.author_id ?? "")} class="overflow-hidden rounded-lg border border-slate-300 bg-white shadow-md transition-shadow hover:shadow-lg relative">
                          {/* Кнопка меню (три точки) - показываем только для автора воспоминания */}
                          {(() => {
                            const authorId = memory.author_id ? Number(memory.author_id) : null;
                            const isAuthor = currentUserId !== null && authorId !== null && currentUserId === authorId;
                            if (!isAuthor) return null;
                            return (
                              <div class="absolute top-3 right-3 z-10" data-memory-menu-container>
                            <button
                              type="button"
                              data-memory-menu-btn
                              data-memory-id={String(memory.id)}
                              class="p-1.5 rounded-lg hover:bg-gray-100 transition-colors text-gray-500 hover:text-gray-700"
                              aria-label="Меню воспоминания"
                            >
                              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                              </svg>
                            </button>
                            {/* Выпадающее меню */}
                            <div
                              data-memory-menu
                              data-memory-id={String(memory.id)}
                              class="hidden absolute right-0 top-full mt-1 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-20 overflow-hidden"
                            >
                              <button
                                type="button"
                                data-memory-edit-btn
                                data-memory-id={String(memory.id)}
                                class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors flex items-center gap-2"
                                disabled
                                title="Редактирование воспоминаний будет доступно позже"
                              >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                </svg>
                                Редактировать
                              </button>
                              <button
                                type="button"
                                data-memory-delete-btn
                                data-memory-id={String(memory.id)}
                                class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors flex items-center gap-2"
                              >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                                Удалить
                              </button>
                            </div>
                          </div>
                            );
                          })()}

                          <div class="flex items-center justify-between px-3 sm:px-4 py-3">
                            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
                              {memory.author_id ? (
                                <a href={`/user/id${memory.author_id}`} class="flex-shrink-0">
                                  <img
                                    src={resolveUserAvatar(memory.author_avatar, memory.author_name)}
                                    alt={memory.author_name ?? "Автор"}
                                    class="w-12 h-12 sm:w-14 sm:h-14 rounded-md object-cover hover:opacity-80 transition-opacity"
                                    loading="lazy"
                                    decoding="async"
                                    width="56"
                                    height="56"
                                  />
                                </a>
                              ) : (
                                <img
                                  src={resolveUserAvatar(memory.author_avatar, memory.author_name)}
                                  alt={memory.author_name ?? "Автор"}
                                  loading="lazy"
                                  decoding="async"
                                  width="56"
                                  height="56"
                                  class="w-12 h-12 sm:w-14 sm:h-14 rounded-md object-cover"
                                />
                              )}

                              <div class="min-w-0 flex-1">
                                <div class="flex items-center gap-1 sm:gap-2 flex-wrap">
                                  {memory.author_name ? (
                                    <a href={memory.author_id ? `/user/id${memory.author_id}` : "#"} class="hover:underline min-w-0 flex items-center gap-1">
                                      <h4 class="font-semibold text-slate-700 text-sm sm:text-base truncate">{memory.author_name}</h4>
                                    </a>
                                  ) : (
                                    <h4 class="font-semibold text-slate-700 text-sm sm:text-base">Пользователь</h4>
                                  )}
                                  {memory.author_relationship && (
                                    <span class="text-xs sm:text-sm text-sky-600 font-medium whitespace-nowrap">• {memory.author_relationship}</span>
                                  )}
                                </div>
                                <p class="text-xs text-gray-500">
                                  {new Date(memory.created_at).toLocaleString("ru-RU")}
                                </p>
                              </div>
                            </div>
                          </div>

                          <div class="px-3 sm:px-4 pb-3">
                            <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-line">
                              {memory.content}
                            </p>
                          </div>

                          {/* Медиа из воспоминания: фото */}
                          {(() => {
                            const photos = memory.photos ?? [];
                            if (!Array.isArray(photos) || photos.length === 0) return null;

                            // Бэкенд уже возвращает полные URL, используем их как есть
                            const resolved = photos
                              .map((path) => (typeof path === "string" ? path.trim() : ""))
                              .filter((path) => path.length > 0);

                            if (resolved.length === 0) return null;

                            if (resolved.length === 1) {
                              const url = resolved[0];
                              return (
                                <div class="px-3 sm:px-4 pb-3">
                                  <div class="relative group cursor-pointer sm:max-w-md">
                                    <div class="aspect-[4/3] rounded-lg overflow-hidden bg-gray-100">
                                      <img
                                        src={url}
                                        alt="Фото воспоминания"
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                      />
                                    </div>
                                  </div>
                                </div>
                              );
                            }

                            if (resolved.length === 2) {
                              return (
                                <div class="px-3 sm:px-4 pb-3">
                                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5 sm:gap-2">
                                    {resolved.map((url) => (
                                      <div class="relative group cursor-pointer">
                                        <div class="aspect-[4/3] rounded-lg overflow-hidden bg-gray-100">
                                          <img
                                            src={url}
                                            alt="Фото воспоминания"
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                          />
                                        </div>
                                      </div>
                                    ))}
                                  </div>
                                </div>
                              );
                            }

                            return (
                              <div class="px-3 sm:px-4 pb-3">
                                <div class="grid grid-cols-2 gap-1.5 sm:gap-2">
                                  {resolved.map((url) => (
                                    <div class="relative group cursor-pointer">
                                      <div class="aspect-[4/3] rounded-lg overflow-hidden bg-gray-100">
                                        <img
                                          src={url}
                                          alt="Фото воспоминания"
                                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                        />
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            );
                          })()}

                          {/* Медиа из воспоминания: видео */}
                          {(() => {
                            const videos = memory.videos ?? [];
                            if (!Array.isArray(videos) || videos.length === 0) return null;

                            // Бэкенд уже возвращает полные URL, используем их как есть
                            const resolved = videos
                              .map((path) => (typeof path === "string" ? path.trim() : ""))
                              .filter((path) => path.length > 0);

                            if (resolved.length === 0) return null;

                            return (
                              <div class="px-3 sm:px-4 pb-3">
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                  {resolved.map((url) => (
                                    <div class="relative aspect-[4/3] rounded-lg overflow-hidden bg-gray-900">
                                      <video
                                        src={url}
                                        controls
                                        preload="metadata"
                                        class="w-full h-full object-cover"
                                      ></video>
                                      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                                        <div class="w-12 h-12 sm:w-16 sm:h-16 bg-white/90 rounded-full flex items-center justify-center">
                                          <svg class="w-6 h-6 sm:w-8 sm:h-8 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z" />
                                          </svg>
                                        </div>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            );
                          })()}

                          <div class="px-3 sm:px-4 py-2 border-t border-gray-100 bg-gray-50">
                            <div class="flex items-center justify-between">
                              <div class="flex items-center gap-3 sm:gap-4">
                                {(() => {
                                  const isLiked = memory.user_liked === true;
                                  return (
                                    <button
                                      type="button"
                                      data-memory-like-btn
                                      data-memory-id={String(memory.id)}
                                      data-memory-liked={String(isLiked)}
                                      class={`flex items-center gap-1.5 transition-colors text-sm ${isLiked ? 'text-red-500' : 'text-gray-500 hover:text-red-600'}`}
                                    >
                                      {isLiked ? (
                                        <svg class="w-4 h-4" fill="#ef4444" viewBox="0 0 24 24">
                                          <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                        </svg>
                                      ) : (
                                        <svg class="w-4 h-4" fill="none" stroke="#6b7280" viewBox="0 0 24 24">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                        </svg>
                                      )}
                                      <span data-memory-likes-count>{toCount(memory.likes)}</span>
                                    </button>
                                  );
                                })()}

                                <button
                                  type="button"
                                  data-memory-comments-toggle
                                  data-memory-id={String(memory.id)}
                                  class="flex items-center gap-1.5 text-gray-500 hover:text-sky-500 transition-colors text-sm"
                                >
                                  <svg class="w-4 h-4" fill="none" stroke="#6b7280" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                  </svg>
                                  <span data-memory-comments-count>{(memory.comments ?? []).length}</span>
                                </button>
                              </div>

                              <div class="flex items-center gap-1.5 text-gray-400 text-xs">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                                <span data-memory-views-count>{toCount(memory.views)}</span>
                              </div>
                            </div>
                          </div>

                          <div data-memory-comments-container data-memory-id={String(memory.id)} class="hidden border-t border-gray-100 px-3 sm:px-4 py-3 bg-gray-50">
                            <div data-memory-comment-form-guest class="hidden pb-3 border-b border-gray-200 mb-3">
                              <p class="text-xs text-gray-600">
                                Войдите, чтобы оставить комментарий.
                                <a href="/login" class="text-sky-600 hover:text-sky-700 ml-1">Войти</a>
                              </p>
                            </div>

                            <form data-memory-comment-form data-memory-id={String(memory.id)} class="hidden flex gap-2 sm:gap-3 pb-3 border-b border-gray-200 mb-3">
                              <img
                                data-memory-comment-form-avatar
                                src=""
                                alt="Вы"
                                class="w-10 h-10 sm:w-12 sm:h-12 rounded-md object-cover flex-shrink-0"
                              />
                              <div class="flex-1 flex flex-col sm:flex-row gap-2">
                                <input
                                  data-memory-comment-input
                                  type="text"
                                  maxlength="500"
                                  placeholder="Написать комментарий..."
                                  class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-xs focus:border-transparent focus:ring-2 focus:ring-sky-200"
                                />
                                <button
                                  type="submit"
                                  class="whitespace-nowrap rounded-lg bg-red-500 px-4 py-2 text-xs text-white transition-colors hover:bg-red-600"
                                >
                                  Отправить
                                </button>
                              </div>
                            </form>

                            <div data-memory-comments-list class="space-y-2 sm:space-y-3">
                              {(memory.comments ?? []).length > 0 ? (
                                (memory.comments ?? []).map((comment) => (
                                  <div class="flex gap-3" data-comment-id={String(comment.id)}>
                                    {comment.author_id ? (
                                      <a href={`/user/id${comment.author_id}`} class="flex-shrink-0">
                                        <img
                                          src={resolveUserAvatar(comment.author_avatar, comment.author_name)}
                                          alt={comment.author_name ?? "Автор"}
                                          class="w-12 h-12 rounded-md object-cover hover:opacity-80 transition-opacity"
                                        />
                                      </a>
                                    ) : (
                                      <img
                                        src={resolveUserAvatar(comment.author_avatar, comment.author_name)}
                                        alt={comment.author_name ?? "Автор"}
                                        class="w-12 h-12 rounded-md object-cover"
                                      />
                                    )}
                                    <div class="flex-1 min-w-0">
                                      <div class="bg-white rounded-lg px-3 py-2 border border-gray-200">
                                        <h5 class="font-semibold text-slate-700 text-sm mb-1">{comment.author_name ?? "Пользователь"}</h5>
                                        <p class="text-slate-600 text-xs leading-relaxed">{comment.content}</p>
                                      </div>
                                      <div class="flex items-center gap-3 mt-1 px-2">
                                        {(() => {
                                          const isLiked = comment.user_liked === true;
                                          return (
                                            <button
                                              type="button"
                                              data-comment-like-btn
                                              data-comment-id={String(comment.id)}
                                              data-comment-liked={String(isLiked)}
                                              class={`flex items-center gap-1 transition-colors text-xs ${isLiked ? 'text-red-500' : 'text-gray-400 hover:text-red-600'}`}
                                            >
                                              {isLiked ? (
                                                <svg class="w-3 h-3" fill="#ef4444" viewBox="0 0 24 24">
                                                  <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
