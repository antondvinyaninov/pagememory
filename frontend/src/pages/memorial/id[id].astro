---
import MainLayout from "../../layouts/MainLayout.astro";
import { declineToGenitive } from "../../lib/decline-name";
import MemorialPageIsland from "../../components/islands/MemorialPageIsland";
import { getApiBaseUrl } from "../../lib/api-url";

const { id } = Astro.params;
const API_BASE_URL = getApiBaseUrl();
const CLIENT_API_URL = import.meta.env.DEV ? 'http://localhost:4000/api' : '/api';

// SSR-передача cookies для определения лайков пользователя
const cookieHeader = Astro.request.headers.get("cookie") ?? "";

// SSR-детекция текущего пользователя для показа меню редактирования
let currentUserId: number | null = null;
if (cookieHeader) {
  try {
    const meRes = await fetch(`${API_BASE_URL}/auth/me`, {
      method: "GET",
      headers: { cookie: cookieHeader },
    });
    if (meRes.ok) {
      const me = await meRes.json().catch(() => null);
      const id = Number(me?.id || 0);
      if (id > 0) {
        currentUserId = id;
      }
    }
  } catch {
    // игнорируем ошибки
  }
}

type MemorialApi = {
  id: number | string;
  first_name: string;
  last_name: string;
  middle_name: string | null;
  birth_date: string | null;
  death_date: string | null;
  birth_place: string | null;
  biography: string | null;
  photo: string | null;
  views: number | string | null;
  religion: string | null;
  full_biography: string | null;
  education_details: string | null;
  career_details: string | null;
  hobbies: string | null;
  character_traits: string | null;
  achievements: string | null;
  military_service: string | null;
  military_rank: string | null;
  military_years: string | null;
  military_details: string | null;
  military_conflicts: string[] | null;
  military_files: { path?: string; title?: string | null }[] | null;
  achievement_files: { path?: string; title?: string | null }[] | null;
  media_photos: string[] | null;
  media_videos: string[] | null;
  burial_city: string | null;
  burial_place: string | null;
  burial_address: string | null;
  burial_location: string | null;
  burial_latitude: number | string | null;
  burial_longitude: number | string | null;
  burial_photos: string[] | null;
  memories?: Array<{
    id: number | string;
    content: string;
    likes: number | string;
    views: number | string;
    created_at: string;
    author_id: number | string | null;
    author_name: string | null;
    author_avatar: string | null;
    author_relationship?: string | null;
    user_liked?: boolean;
    photos?: string[] | null;
    videos?: string[] | null;
    comments?: Array<{
      id: number | string;
      memory_id: number | string;
      content: string;
      likes: number | string;
      created_at: string;
      author_id: number | string | null;
      author_name: string | null;
      author_avatar: string | null;
      user_liked?: boolean;
    }>;
  }>;
};

let memorial: MemorialApi | null = null;
let error: string | null = null;

if (id) {
  try {
    const res = await fetch(`${API_BASE_URL}/memorials/${id}`, {
      headers: cookieHeader ? { cookie: cookieHeader } : {},
    });
    if (!res.ok) {
      error = `Не удалось загрузить мемориал (код ${res.status})`;
    } else {
      memorial = (await res.json()) as MemorialApi;
    }
  } catch {
    error = "Ошибка подключения к API мемориалов";
  }
} else {
  error = "Не указан идентификатор мемориала";
}

// Простейший аналог Laravel Storage::url для фото мемориала.
// Если в БД уже лежит полный URL (начинается с http/https) — используем его как есть.
// Если там только путь (например, "memorials/1/photo.jpg"), можно задать базовый URL S3.
// Публичный URL для S3-хранилища FirstVDS (bucket: memory).
// При необходимости можно будет поменять на CDN/домен.
const S3_BASE_URL = import.meta.env.PUBLIC_S3_BASE_URL ?? "https://s3.firstvds.ru/memory";
const YANDEX_MAPS_API_KEY = import.meta.env.PUBLIC_YANDEX_MAPS_API_KEY ?? "";

function resolvePhotoUrl(memorial: MemorialApi): string {
  if (memorial.photo) {
    if (memorial.photo.startsWith("http://") || memorial.photo.startsWith("https://")) {
      return memorial.photo;
    }
    if (S3_BASE_URL) {
      return `${S3_BASE_URL.replace(/\/$/, "")}/${memorial.photo.replace(/^\//, "")}`;
    }
  }

  // Фолбэк — сервис аватаров, как в Laravel hero
  return `https://ui-avatars.com/api/?name=${encodeURIComponent(
    `${memorial.first_name} ${memorial.last_name}`,
  )}&size=300&background=e5e7eb&color=6b7280&bold=true`;
}

/**
 * Генерирует URL маленького изображения - просто фото человека из мемориала
 * Используется для summary card в Twitter и других соцсетях
 */
function resolvePhotoUrlSmall(memorial: MemorialApi): string {
  // Просто возвращаем фото мемориала - это будет маленькое изображение
  return resolvePhotoUrl(memorial);
}

/**
 * Генерирует URL изображения для Open Graph
 * Использует endpoint /og-image/[id] который генерирует PNG через @vercel/og
 */
function resolvePhotoUrlForOG(memorial: MemorialApi): string {
  const origin = import.meta.env.PUBLIC_APP_URL || "https://pagesofmemory.ru";
  return `${origin}/og-image/${memorial.id}`;
}

function resolveS3Path(path: string): string {
  const trimmed = path.trim();
  if (trimmed.startsWith("http://") || trimmed.startsWith("https://")) {
    return trimmed;
  }
  return `${S3_BASE_URL.replace(/\/$/, "")}/${trimmed.replace(/^\//, "")}`;
}

function toNumberOrNull(value: unknown): number | null {
  if (value === null || value === undefined) return null;
  const normalized = String(value).trim().replace(",", ".");
  if (!normalized) return null;
  const parsed = Number(normalized);
  return Number.isFinite(parsed) ? parsed : null;
}

function toCount(value: unknown): number {
  const parsed = toNumberOrNull(value);
  return parsed === null ? 0 : Math.max(0, Math.trunc(parsed));
}

function resolveUserAvatar(path: string | null | undefined, name: string | null | undefined): string {
  if (typeof path === "string" && path.trim()) {
    return resolveS3Path(path);
  }
  const fallbackName = String(name || "User").trim() || "User";
  return `https://ui-avatars.com/api/?name=${encodeURIComponent(fallbackName)}&size=128&background=e3f2fd&color=1976d2&bold=true`;
}

const memorialPhotos = memorial?.media_photos ?? [];
const memorialVideos = memorial?.media_videos ?? [];
const burialPhotos = memorial?.burial_photos ?? [];
const hasBurialTextInfo = Boolean(
  memorial?.burial_city || memorial?.burial_place || memorial?.burial_address || memorial?.burial_location,
);
const burialLatitude = toNumberOrNull(memorial?.burial_latitude);
const burialLongitude = toNumberOrNull(memorial?.burial_longitude);
const hasBurialMap = burialLatitude !== null && burialLongitude !== null;
const hasBurialData = hasBurialTextInfo || burialPhotos.length > 0 || hasBurialMap;
const hasMediaData = memorialPhotos.length > 0 || memorialVideos.length > 0 || burialPhotos.length > 0;

// closePeople будет загружен динамически через API
---

<MainLayout
  title={memorial ? `${memorial.last_name} ${memorial.first_name} ${memorial.middle_name ?? ""}`.trim() : "Страница памяти"}
  metaTitle={memorial ? `${memorial.last_name} ${memorial.first_name} ${memorial.middle_name ?? ""}`.trim() : "Страница памяти"}
  metaDescription={
    memorial
      ? `Страница памяти о ${memorial.last_name} ${memorial.first_name} ${memorial.middle_name ?? ""}`.trim() +
        (memorial.birth_date || memorial.death_date
          ? `. ${memorial.birth_date ? `Родился: ${memorial.birth_date}` : ""} ${memorial.death_date ? `Умер: ${memorial.death_date}` : ""}`
          : "") +
        (memorial.biography ? `. ${memorial.biography.substring(0, 150)}...` : "")
      : "Цифровая страница памяти о близком человеке"
  }
  metaImage={memorial ? resolvePhotoUrlForOG(memorial) : undefined}
  metaImageSmall={memorial ? resolvePhotoUrlSmall(memorial) : undefined}
  metaImageWidth={1200}
  metaImageHeight={630}
  metaType="article"
>
  <div class="min-h-screen bg-slate-100 pt-4 sm:pt-6">
    {/* Сообщения об ошибке / загрузке */}
    <div class="container mx-auto px-4 pb-4">
      {error && (
        <div class="rounded-xl border border-red-300 bg-red-50 p-4 text-sm text-red-700">
          {error}
        </div>
      )}

      {!error && !memorial && (
        <div class="rounded-xl border border-slate-300 bg-white p-4 text-sm text-slate-600">
          Загрузка мемориала...
        </div>
      )}
    </div>

      {memorial && (
        <>
          {/* HERO-блок, максимально похожий на Laravel */}
          <div class="mb-5 sm:mb-6">
            <div class="container mx-auto px-4">
              <div class="relative overflow-hidden rounded-2xl border border-slate-700 bg-slate-800 text-white shadow-xl">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.16),_transparent_46%),radial-gradient(circle_at_bottom_left,_rgba(100,116,139,0.22),_transparent_50%),linear-gradient(135deg,_#1e293b_0%,_#111827_55%,_#0b1120_100%)]"></div>
                <div class="absolute -top-28 -left-20 w-72 h-72 rounded-full bg-slate-500/25 blur-3xl"></div>
                <div class="absolute -bottom-32 -right-16 w-80 h-80 rounded-full bg-sky-500/20 blur-3xl"></div>

                {memorial.religion === "orthodox" && (
                  <div class="absolute top-5 right-5 sm:top-7 sm:right-7 z-20">
                    <svg viewBox="0 0 24 24" class="w-10 h-10 sm:w-12 sm:h-12 text-white drop-shadow">
                      <path d="M12 2v20M8 6h8M6 10h12M8 18h8" stroke="currentColor" stroke-width="2" fill="none"/>
                      <path d="M12 2L10 4h4l-2-2zM12 22l-2-2h4l-2 2z" fill="currentColor"/>
                    </svg>
                  </div>
                )}

                <div class="relative z-10 px-4 pb-5 pt-16 sm:px-7 sm:pb-7 sm:pt-20 lg:px-8 lg:py-8">
                  <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:gap-10">
                    {/* Фото / аватар */}
                    <div class="mx-auto w-full max-w-sm overflow-hidden rounded-2xl border border-white/20 bg-slate-500/20 shadow-lg aspect-square sm:h-[22rem] sm:w-[22rem] lg:mx-0 lg:h-64 lg:w-64">
                      <img
                        src={resolvePhotoUrl(memorial)}
                        alt={`${memorial.first_name} ${memorial.last_name}`}
                        class="w-full h-full object-cover"
                        loading="eager"
                        decoding="async"
                        fetchpriority="high"
                        width="400"
                        height="400"
                      />
                    </div>

                    {/* Текстовая часть */}
                    <div class="min-w-0 flex-1 text-center lg:text-left">
                      <h1 class="text-3xl font-extrabold leading-tight sm:text-4xl lg:text-5xl">
                        {`${memorial.last_name} ${memorial.first_name} ${
                          memorial.middle_name ?? ""
                        }`.trim()}
                      </h1>

                      <div class="mt-4 inline-flex flex-wrap items-center justify-center gap-2 rounded-xl border border-white/45 bg-slate-900/45 px-3 py-2 text-sm sm:text-base lg:justify-start">
                        <span class="font-semibold text-white">
                          {memorial.birth_date
                            ? (() => {
                                const date = new Date(memorial.birth_date);
                                const day = String(date.getDate()).padStart(2, "0");
                                const month = String(date.getMonth() + 1).padStart(2, "0");
                                const year = date.getFullYear();
                                return `${day}.${month}.${year}`;
                              })()
                            : "—"}
                        </span>
                        <span class="text-white">—</span>
                        <span class="font-semibold text-white">
                          {memorial.death_date
                            ? (() => {
                                const date = new Date(memorial.death_date);
                                const day = String(date.getDate()).padStart(2, "0");
                                const month = String(date.getMonth() + 1).padStart(2, "0");
                                const year = date.getFullYear();
                                return `${day}.${month}.${year}`;
                              })()
                            : "—"}
                        </span>
                      </div>

                      {memorial.birth_place && (
                        <div class="mt-4 flex items-center justify-center gap-2 text-slate-100 lg:justify-start">
                          <svg
                            class="w-4 h-4 sm:w-5 sm:h-5 text-white/90"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                          </svg>
                          <span class="text-sm sm:text-base">
                            {memorial.birth_place}
                          </span>
                        </div>
                      )}

                      {memorial.biography && (
                        <p class="mt-4 max-w-3xl text-base italic text-slate-100 sm:text-lg lg:mt-5">
                          {memorial.biography}
                        </p>
                      )}

                      <div class="mt-5 flex flex-wrap items-center justify-center gap-2 lg:justify-start">
                        <span class="inline-flex items-center gap-1 rounded-full border border-white/45 bg-slate-900/55 px-3 py-1 text-xs font-semibold text-white">
                          <svg
                            class="w-4 h-4 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                            ></path>
                          </svg>
                          {(memorial.memories?.length ?? 0).toString()}{" "}
                          воспоминаний
                        </span>
                        <span class="inline-flex items-center gap-1 rounded-full border border-white/45 bg-slate-900/55 px-3 py-1 text-xs font-semibold text-white">
                          <svg
                            class="w-4 h-4 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path>
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                            ></path>
                          </svg>
                          {toCount(memorial.views)} просмотров
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="sticky top-[60px] z-30 mb-4 px-3 lg:hidden">
            <div class="rounded-2xl border border-slate-300 bg-white p-2 shadow-md backdrop-blur-sm">
              <div class="flex gap-1 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
                <button
                  type="button"
                  data-tab-btn="memories"
                  class="flex shrink-0 items-center gap-2 rounded-lg border px-3 py-2 text-xs font-medium transition-colors"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                  </svg>
                  <span>Воспоминания</span>
                </button>
                <button
                  type="button"
                  data-tab-btn="about"
                  class="flex shrink-0 items-center gap-2 rounded-lg border px-3 py-2 text-xs font-medium transition-colors"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <span>О человеке</span>
                </button>
                <button
                  type="button"
                  data-tab-btn="burial"
                  class="flex shrink-0 items-center gap-2 rounded-lg border px-3 py-2 text-xs font-medium transition-colors"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  </svg>
                  <span>Захоронение</span>
                </button>
                <button
                  type="button"
                  data-tab-btn="media"
                  class="flex shrink-0 items-center gap-2 rounded-lg border px-3 py-2 text-xs font-medium transition-colors"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span>Медиа</span>
                </button>
                <button
                  type="button"
                  data-tab-btn="people"
                  class="flex shrink-0 items-center gap-2 rounded-lg border px-3 py-2 text-xs font-medium transition-colors"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                  </svg>
                  <span>Близкие люди</span>
                </button>
              </div>
            </div>
          </div>

          {/* Сетка: сайдбар навигации + вкладки */}
          <div
            class="container mx-auto px-4 pb-16"
            id="memorial-tabs-root"
            data-api-base-url={CLIENT_API_URL}
            data-memorial-id={String(memorial.id)}
          >
            <div class="grid gap-5 lg:grid-cols-[19rem_1fr]">
              {/* Сайдбар навигации по вкладкам */}
              <aside class="hidden h-fit lg:block lg:sticky lg:top-6">
                <div class="rounded-2xl border border-slate-300 bg-white p-4 shadow-md backdrop-blur-sm">
                  <div class="mb-3 px-2">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-700">
                      Навигация
                    </p>
                  </div>
                  <nav class="space-y-1.5">
                    <button
                      type="button"
                      data-tab-btn="memories"
                      class="flex w-full items-center gap-3 rounded-xl border px-3 py-3 text-left text-sm font-medium transition-all duration-200"
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                      </svg>
                      <span>Воспоминания</span>
                    </button>
                    <button
                      type="button"
                      data-tab-btn="about"
                      class="flex w-full items-center gap-3 rounded-xl border px-3 py-3 text-left text-sm font-medium transition-all duration-200"
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      <span>О человеке</span>
                    </button>
                    <button
                      type="button"
                      data-tab-btn="burial"
                      class="flex w-full items-center gap-3 rounded-xl border px-3 py-3 text-left text-sm font-medium transition-all duration-200"
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      </svg>
                      <span>Захоронение</span>
                    </button>
                    <button
                      type="button"
                      data-tab-btn="media"
                      class="flex w-full items-center gap-3 rounded-xl border px-3 py-3 text-left text-sm font-medium transition-all duration-200"
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <span>Медиа</span>
                    </button>
                    <button
                      type="button"
                      data-tab-btn="people"
                      class="flex w-full items-center gap-3 rounded-xl border px-3 py-3 text-left text-sm font-medium transition-all duration-200"
                    >
