                              </div>
                            )}
                            {memorial.burial_place && (
                              <div class="px-3 py-2">
                                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-400">
                                  Кладбище
                                </dt>
                                <dd class="mt-1 text-sm font-medium text-slate-700">
                                  {memorial.burial_place}
                                </dd>
                              </div>
                            )}
                            {memorial.burial_address && (
                              <div class="px-3 py-2">
                                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-400">
                                  Адрес
                                </dt>
                                <dd class="mt-1 text-sm font-medium text-slate-700">
                                  {memorial.burial_address}
                                </dd>
                              </div>
                            )}
                            {memorial.burial_location && (
                              <div class="px-3 py-2">
                                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-400">
                                  Расположение
                                </dt>
                                <dd class="mt-1 text-sm font-medium text-slate-700">
                                  {memorial.burial_location}
                                </dd>
                              </div>
                            )}
                          </dl>
                        </section>
                      )}

                      {burialPhotos.length > 0 && (
                        <section>
                          <h3 class="text-base font-semibold text-slate-800 mb-3">
                            Фотографии места
                          </h3>
                          <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4">
                            {burialPhotos.map((path) => {
                              const url = resolveS3Path(path);
                              return (
                                <a
                                  href={url}
                                  target="_blank"
                                  rel="noreferrer"
                                  class="group relative block overflow-hidden rounded-lg border border-slate-300 bg-white"
                                >
                                  <div class="aspect-square">
                                    <img
                                      src={url}
                                      alt="Фото места захоронения"
                                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                    />
                                  </div>
                                </a>
                              );
                            })}
                          </div>
                        </section>
                      )}

                      {hasBurialMap && (
                        <section>
                          <h3 class="text-base font-semibold text-slate-800 mb-3">
                            Местоположение на карте
                          </h3>
                          <div
                            id="burial-map-view"
                            data-latitude={String(burialLatitude)}
                            data-longitude={String(burialLongitude)}
                            data-map-key={YANDEX_MAPS_API_KEY}
                            class="h-64 w-full rounded-xl border border-slate-300 bg-white sm:h-80 md:h-96"
                          ></div>
                          <p class="mt-2 text-xs text-gray-500">
                            Координаты: {burialLatitude}, {burialLongitude}
                          </p>
                        </section>
                      )}
                    </div>
                  ) : (
                    <p class="text-sm text-slate-600">
                      Информация о месте захоронения пока не заполнена.
                    </p>
                  )}
                    </div>
                  </div>
                </div>

                <div data-tab-section="media">
                  <section class="overflow-hidden rounded-2xl border border-slate-300 bg-white shadow-md">
                    <header class="border-b border-slate-700 bg-slate-700 px-4 py-4 sm:px-6">
                      <h2 class="flex items-center gap-2 text-base font-semibold text-white sm:text-lg">
                        <svg class="h-4 w-4 text-sky-200 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        Медиа
                      </h2>
                    </header>
                  </section>
                  <div class="mt-4">
                    <div class="rounded-2xl border border-slate-300 bg-white p-4 shadow-md">
                      {hasMediaData ? (
                    <div class="space-y-5">
                      {memorialPhotos.length > 0 && (
                        <section>
                          <h3 class="text-base font-semibold text-slate-800 mb-3">
                            Фотографии мемориала ({memorialPhotos.length})
                          </h3>
                          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
                            {memorialPhotos.map((path) => {
                              const url = resolveS3Path(path);
                              return (
                                <a
                                  href={url}
                                  target="_blank"
                                  rel="noreferrer"
                                  class="group relative block overflow-hidden rounded-xl shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
                                >
                                  <div class="aspect-square overflow-hidden bg-gray-100">
                                    <img
                                      src={url}
                                      alt="Фото мемориала"
                                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                                    />
                                  </div>
                                </a>
                              );
                            })}
                          </div>
                        </section>
                      )}

                      {memorialVideos.length > 0 && (
                        <section>
                          <h3 class="text-base font-semibold text-slate-800 mb-3">
                            Видео мемориала ({memorialVideos.length})
                          </h3>
                          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            {memorialVideos.map((path) => {
                              const url = resolveS3Path(path);
                              return (
                                <div class="relative overflow-hidden rounded-xl bg-gray-900 shadow-md">
                                  <div class="aspect-video">
                                    <video
                                      src={url}
                                      controls
                                      preload="metadata"
                                      class="h-full w-full object-cover"
                                    ></video>
                                  </div>
                                </div>
                              );
                            })}
                          </div>
                        </section>
                      )}

                      {burialPhotos.length > 0 && (
                        <section>
                          <h3 class="text-base font-semibold text-slate-800 mb-3">
                            Фото места захоронения ({burialPhotos.length})
                          </h3>
                          <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4">
                            {burialPhotos.map((path) => {
                              const url = resolveS3Path(path);
                              return (
                                <a
                                  href={url}
                                  target="_blank"
                                  rel="noreferrer"
                                  class="group relative block overflow-hidden rounded-lg border border-slate-300 bg-white"
                                >
                                  <div class="aspect-square">
                                    <img
                                      src={url}
                                      alt="Фото места захоронения"
                                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                    />
                                  </div>
                                </a>
                              );
                            })}
                          </div>
                        </section>
                      )}
                    </div>
                  ) : (
                    <p class="text-sm text-slate-600">
                      Фото и видео пока не добавлены.
                    </p>
                  )}
                    </div>
                  </div>
                </div>

                <div data-tab-section="people">
                  <section class="overflow-hidden rounded-2xl border border-slate-300 bg-white shadow-md">
                    <header class="border-b border-slate-700 bg-slate-700 px-4 py-4 sm:px-6">
                      <h2 class="flex items-center gap-2 text-base font-semibold text-white sm:text-lg">
                        <svg class="h-4 w-4 text-sky-200 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                        Близкие люди
                      </h2>
                    </header>
                  </section>
                  <div class="mt-4">
                    <div class="rounded-2xl border border-slate-300 bg-white p-4 shadow-md">
                      <div id="people-list-container">
                        <p class="text-sm text-slate-600">Загрузка...</p>
                      </div>
                    </div>
                  </div>
                </div>
              </main>
            </div>
          </div>
        </>
      )}
    </div>
  </div>
</MainLayout>
<MemorialPageIsland client:idle />

<script>
  function openPhotoModal(url: string) {
    const modal = document.createElement("div");
    modal.className = "fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4";
    modal.onclick = () => modal.remove();
    
    const img = document.createElement("img");
    img.src = url;
    img.className = "max-h-full max-w-full object-contain";
    img.onclick = (e) => e.stopPropagation();
    
    modal.appendChild(img);
    document.body.appendChild(modal);
  }
  
  // Делаем функцию глобальной для использования в onclick
  (window as any).openPhotoModal = openPhotoModal;
</script>
