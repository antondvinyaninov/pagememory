---
interface Props {
  active: "edit" | "security" | "privacy";
}

const { active } = Astro.props as Props;

const items = [
  { key: "edit", href: "/user/edit", label: "Основная информация" },
  { key: "security", href: "/user/security", label: "Безопасность" },
  { key: "privacy", href: "/user/privacy", label: "Приватность" },
] as const;
---

<aside class="lg:w-80 lg:sticky lg:top-4 lg:h-fit">
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <nav class="p-4">
      {items.map((item) => (
        <a
          href={item.href}
          class:list={[
            "flex items-center gap-3 px-4 py-3 rounded-lg transition-colors",
            active === item.key ? "text-gray-700 bg-red-50 font-medium" : "text-gray-600 hover:bg-gray-50",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</aside>
