## Astro frontend environment (example)
## Copy to .env (file is gitignored) and fill values for your environment.
## ⚠️ ВАЖНО: В продакшене обязательно укажите правильные URL!

# Base URL of Nest API (without trailing slash)
# Для разработки: http://localhost:4000/api
# Для продакшена: https://api.yourdomain.com/api
PUBLIC_API_BASE_URL=http://localhost:4000/api

# Public app URL for links in QR and emails
# Для разработки: http://localhost:4321
# Для продакшена: https://pagesofmemory.ru
PUBLIC_APP_URL=https://pagesofmemory.ru

# Base URL for S3 public bucket (without trailing slash)
PUBLIC_S3_BASE_URL=https://s3.firstvds.ru/memory

# UI
PUBLIC_SITE_NAME=Страницы памяти
PUBLIC_PROJECT_ICON_URL=/brand/memory-icon.png

# Analytics (optional)
PUBLIC_GTM_ID=

# Yandex Maps
PUBLIC_YANDEX_MAPS_API_KEY=

# DaData API (optional, can be used directly from frontend)
PUBLIC_DADATA_TOKEN=
