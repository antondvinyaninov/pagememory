## NestJS backend environment (example)
## Copy to .env (file is gitignored) and fill values for your environment.
## ⚠️ ВАЖНО: В продакшене обязательно укажите правильные значения!

# HTTP
PORT=4000
# HOST для продакшена обычно 0.0.0.0 (слушать на всех интерфейсах)
HOST=0.0.0.0
# PROTOCOL: http для разработки, https для продакшена
PROTOCOL=http
# DOMAIN: localhost:4000 для разработки, ваш домен для продакшена (например: api.yourdomain.com)
DOMAIN=localhost:4000
# APP_URL: URL фронтенда для ссылок в письмах и QR-кодах
# Для разработки: http://localhost:4321
# Для продакшена: https://pagesofmemory.ru
APP_URL=https://pagesofmemory.ru

# Auth
# ⚠️ ОБЯЗАТЕЛЬНО измените в продакшене на случайную строку длиной минимум 32 символа!
# Генерация: openssl rand -base64 32
JWT_SECRET=change-me-in-prod
# Set to "true" in production behind HTTPS so cookies are marked Secure
COOKIE_SECURE=false

# Rate Limiting (опционально, можно настроить через ThrottlerModule)
# По умолчанию: 10 req/sec, 100 req/min, 1000 req/15min
# Для auth endpoints: 5 login/min, 3 register/min

# CORS (comma-separated list)
# Для разработки: http://localhost:4321,http://127.0.0.1:4321
# Для продакшена: https://pagesofmemory.ru,https://www.pagesofmemory.ru
CORS_ORIGINS=https://pagesofmemory.ru,https://www.pagesofmemory.ru

# Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=postgres
DB_SSL=false

# Mail (same semantics as Laravel .env)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=
# Для продакшена укажите реальный email адрес
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=Страницы памяти
PROJECT_ICON_URL=

# S3 (same storage as Laravel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=
AWS_ENDPOINT=https://storage.yandexcloud.net
AWS_USE_PATH_STYLE_ENDPOINT=false

# DaData API for address autocomplete
DADATA_TOKEN=300ba9e25ef32f0d6ea7c41826b2255b138e19e2
